# Terraform Variables Example
# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored and will not be committed
#
# LEGEND:
# [REQUIRED] - Must be customized for your deployment
# [RECOMMENDED] - Should be customized for production
# [OPTIONAL] - Can use defaults, customize if needed

# AWS Configuration
aws_region  = "us-east-1"   # [RECOMMENDED] Choose your preferred region
environment = "prod"         # [REQUIRED] Environment name (prod/staging/dev)

# Project Information
project_name = "my-project"  # [RECOMMENDED] Customize for resource naming
owner        = "YourTeam"    # [OPTIONAL] Team or individual owner

# Domain Configuration
domain_name = "example.com"  # [REQUIRED] Your primary domain (subdomains: admin.*, auth.*, files.*)

# Network Configuration
vpc_cidr           = "10.0.0.0/16"                  # [OPTIONAL] VPC CIDR block
availability_zones = ["us-east-1a", "us-east-1b"]   # [OPTIONAL] Auto-detected if using defaults

# Bastion Configuration
bastion_instance_type = "t4g.nano"  # [OPTIONAL] EC2 instance type for bastion host

# Aurora Serverless v2 Configuration
aurora_min_capacity          = 0.5   # [OPTIONAL] Minimum ACUs (0.5-256)
aurora_max_capacity          = 4     # [OPTIONAL] Maximum ACUs (0.5-256)
aurora_engine_version        = "17.4" # [OPTIONAL] PostgreSQL version
aurora_backup_retention_days = 30     # [OPTIONAL] Backup retention period (7-35 days)
enable_http_endpoint         = false  # [OPTIONAL] Aurora Data API HTTP endpoint

# ElastiCache Serverless Configuration
elasticache_data_storage_gb = 2  # [OPTIONAL] Maximum data storage in GB (1-5000)

# App Runner Configuration
# app_runner_services = { ... }  # [OPTIONAL] See variable default in variables.tf
# service_image_tags  = { ... }  # [OPTIONAL] See variable default in variables.tf

# S3 Buckets
s3_buckets = [  # [RECOMMENDED] Customize bucket types for your needs
  "images",
  "documents",
  "miniatures",
  "character-portraits"
]

# CloudWatch Configuration
log_retention_days = 7  # [OPTIONAL] Log retention in days

# CloudTrail Configuration
cloudtrail_log_retention_days = 90    # [OPTIONAL] CloudTrail log retention in days
enable_cloudtrail_alarms      = true  # [OPTIONAL] Security event alarms

# Monitoring Configuration
alarm_email_addresses = ["ops@example.com"]  # [RECOMMENDED] CloudWatch alarm notification emails

# Feature Flags
enable_enhanced_monitoring  = true  # [OPTIONAL] RDS detailed metrics
enable_performance_insights = true  # [OPTIONAL] RDS query analysis
enable_xray_tracing         = true  # [OPTIONAL] X-Ray tracing for App Runner
enable_vpc_flow_logs        = true  # [OPTIONAL] VPC network traffic logging
enable_guardduty            = true  # [OPTIONAL] Threat detection service
enable_budgets              = false # [OPTIONAL] Cost control and budget alerts
monthly_budget_limit        = 100   # [OPTIONAL] Monthly budget in USD
budget_alert_emails         = ["alerts@example.com"]  # [REQUIRED IF enable_budgets=true]

# Email Forwarding (SES Receiving)
email_forwarding_rules = {  # [OPTIONAL] Recipient → forwarding address
  # "privacy@yourdomain.com" = "your@email.com"
}

# Additional Tags
additional_tags = {  # [OPTIONAL] Custom resource tags
  CostCenter = "Engineering"
}
